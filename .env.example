# Environment variables
# Copy to `.env.local` for local development. Never commit real secrets.

# Fail production-style builds when MP4 / captions / poster are missing
# REQUIRE_VIDEO_ASSETS=1

# n8n webhook (server-only — never expose to the browser)
# Production webhook URL for the Enquiry Reviews workflow
N8N_WEBHOOK_URL=
# Shared HMAC secret used to sign X-Standout-Signature (timestamp.body)
N8N_WEBHOOK_SECRET=

# Analytics (Phase 5) — privacy-conscious; omit or set provider=none to disable
# NEXT_PUBLIC_ANALYTICS_PROVIDER=plausible
# Plausible site domain (also accepted as NEXT_PUBLIC_ANALYTICS_ID)
# NEXT_PUBLIC_ANALYTICS_DOMAIN=standoutgroup.net
